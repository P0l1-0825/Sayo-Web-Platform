# ============================================================
# SAYO Web Platform — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# Get Supabase keys from: https://supabase.com/dashboard/project/_/settings/api
# ============================================================

# ── Supabase (Required for production) ──
# Project URL (e.g., https://xxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
# Anonymous Key (safe for client-side, RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Demo Mode ──
# Set to "true" to enable demo mode (no Supabase required)
# When Supabase vars are empty, demo mode activates automatically
NEXT_PUBLIC_DEMO_MODE=true

# ── App Configuration ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SAYO
NEXT_PUBLIC_COMPANY_NAME=SOLVENDOM SOFOM E.N.R.

# ============================================================
# Server-side only (Edge Functions / Service Role)
# ============================================================
# ⚠️  NEVER expose these in client-side code!

# Supabase Service Role Key (full access, bypasses RLS)
# SUPABASE_SERVICE_ROLE_KEY=

# ── Email (Resend) ──
# RESEND_API_KEY=
# SENDER_EMAIL=notificaciones@sayo.mx

# ── SMS (Twilio) ──
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+52...

# ── Push Notifications (Firebase) ──
# FCM_SERVER_KEY=

# ── SPEI Webhook ──
# SPEI_WEBHOOK_SECRET=your-hmac-secret-here

# ── Database Direct URL (for migrations) ──
# Set SUPABASE_DB_URL in your .env.local (not here) — see Supabase dashboard for connection string
